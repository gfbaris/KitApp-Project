  "variable": [
    {
      "key": "baseUrl",
      "value": "https://kitapp-api.vercel.app",
      "type": "string"
    },
    {
      "key": "token",
      "value": "(login'den sonra manuel doldurulacak)",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "(register'dan sonra manuel doldurulacak)",
      "type": "string"
    },
    {
      "key": "bookId",
      "value": "(kitap ekledikten sonra manuel doldurulacak)",
      "type": "string"
    }
  ]
