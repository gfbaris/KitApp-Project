    {
      "name": "📚 Kitaplar",
      "item": [
        {
          "name": "Add Book",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"Suç ve Ceza\",\"author\":\"Dostoyevski\",\n          \"isbn\":\"978-975-10-3441-2\",\"pageCount\":687,\n          \"publishYear\":1866,\"genre\":\"Roman\",\n          \"description\":\"Klasik bir roman.\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/books",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ]
            }
          }
        },
        {
          "name": "Get Books",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/books?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Search Books",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/books/search?query=Suç",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books",
                "search"
              ],
              "query": [
                {
                  "key": "query",
                  "value": "Suç"
                }
              ]
            }
          }
        },
        {
          "name": "Filter Books by Genre",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/books/filter?genre=Roman",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books",
                "filter"
              ],
              "query": [
                {
                  "key": "genre",
                  "value": "Roman"
                }
              ]
            }
          }
        },
        {
          "name": "Get Book Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
